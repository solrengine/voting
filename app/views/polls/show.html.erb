<% content_for :title, @snapshot.poll_account&.poll_name || @snapshot.poll_config.name %>
<% content_for :description, "#{@snapshot.poll_account&.poll_description || @snapshot.poll_config.description} — on-chain voting on Solana devnet." %>

<div class="max-w-3xl mx-auto px-6 py-12">
  <header class="mb-10">
    <div class="mb-4">
      <%= render Solrengine::Ui::BadgeComponent.new(text: "Solana Devnet", variant: :purple) %>
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-3">
      <%= @snapshot.poll_account&.poll_name || @snapshot.poll_config.name %>
    </h1>
    <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed">
      <%= @snapshot.poll_account&.poll_description || @snapshot.poll_config.description %>
    </p>
  </header>

  <%= render "state_banner", voting_state: @snapshot.voting_state, poll: @snapshot.poll_account %>

  <ol class="mt-8 space-y-4">
    <% @snapshot.candidates.each do |candidate| %>
      <li class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900/50 p-5"
          data-controller="voting"
          data-voting-candidate-value="<%= candidate.name %>"
          data-voting-wallet-address-value="<%= current_user.wallet_address %>"
          data-voting-prepare-url-value="<%= poll_prepare_vote_path %>">
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <div class="flex items-center gap-3 mb-1">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white truncate">
                <%= candidate.name %>
              </h2>
              <span class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400">
                <span class="tabular-nums font-mono"><%= candidate.votes %></span>
                <span><%= "vote".pluralize(candidate.votes) %></span>
              </span>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              <%= candidate.description %>
            </p>
            <% if candidate.url.present? %>
              <a href="<%= candidate.url %>" target="_blank" rel="noopener"
                 class="inline-block mt-2 text-xs text-purple-600 dark:text-purple-400 hover:underline">
                <%= candidate.url %> ↗
              </a>
            <% end %>
          </div>

          <% if @snapshot.open? %>
            <button type="button"
                    data-voting-target="button"
                    data-action="click->voting#vote"
                    class="shrink-0 inline-flex items-center gap-2 bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-500 hover:to-blue-500 text-white text-sm font-semibold py-2 px-4 rounded-lg transition-all duration-150 cursor-pointer">
              Vote
            </button>
          <% end %>
        </div>
        <p data-voting-target="status" class="text-sm mt-2"></p>
      </li>
    <% end %>
  </ol>

  <footer class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-800 text-xs text-gray-500 dark:text-gray-500 space-y-1">
    <p>
      Program:
      <a href="https://solscan.io/account/<%= @snapshot.program_id %>?cluster=devnet" target="_blank" rel="noopener" class="font-mono underline hover:no-underline">
        <%= @snapshot.program_id %>
      </a>
    </p>
    <p>
      Built with <a href="https://solrengine.org" class="underline hover:no-underline">SolRengine</a> —
      Rails + Anchor, one wallet, one click.
    </p>
  </footer>
</div>
