<% content_for :title, "Vote on the next SolRengine showcase" %>
<% content_for :description, "Community vote on Solana devnet: pick the next dApp we feature on solrengine.org." %>

<div class="bg-gradient-to-br from-gray-950 via-gray-900 to-purple-950">
  <nav class="border-b border-gray-800/50">
    <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <svg class="w-7 h-7 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-xl font-bold text-white">Voting</span>
      </div>
      <div class="flex items-center">
        <%= link_to "Connect Wallet", solrengine_auth.login_path, class: "bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-500 hover:to-blue-500 text-white text-sm font-medium py-2 px-4 rounded-lg transition-all duration-200" %>
      </div>
    </div>
  </nav>

  <%# Hero %>
  <div class="max-w-5xl mx-auto px-6 pt-20 pb-20">
    <div class="flex flex-col items-center text-center">
      <div class="mb-6">
        <%= render Solrengine::Ui::BadgeComponent.new(text: "Solana Devnet", variant: :purple) %>
      </div>

      <h1 class="text-5xl sm:text-6xl font-bold text-white leading-tight mb-4 max-w-3xl">
        Pick the next dApp<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-blue-400">we showcase</span>
      </h1>

      <p class="text-lg text-gray-400 leading-relaxed mb-10 max-w-xl">
        Community vote on Solana devnet. Connect your wallet, pick your favorite, and help decide which SolRengine dApp goes on the homepage next.
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <%= link_to solrengine_auth.login_path, class: "inline-flex items-center gap-2 bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-500 hover:to-blue-500 text-white font-semibold py-3 px-6 rounded-xl transition-all duration-200" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          Connect Wallet to Vote
        <% end %>
        <a href="https://solscan.io/account/2F1Z4eTmFqbjAnNWaDXXScoBYLMFn1gTasVy2mfPTeJx?cluster=devnet" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-gray-300 font-semibold py-3 px-6 rounded-xl transition-all duration-200 border border-gray-700">
          View Program on Solscan
        </a>
      </div>
    </div>
  </div>

  <%# Candidates %>
  <div class="max-w-3xl mx-auto px-6 pb-24">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-6 text-center">Candidates</h2>
    <ul class="space-y-3">
      <% Voting::CandidateConfig.candidates.each do |c| %>
        <li class="flex items-center gap-4 bg-gray-800/30 border border-gray-700/50 rounded-xl p-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-purple-600 to-blue-600 flex items-center justify-center text-white font-bold">
            <%= c.name[0] %>
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-white font-semibold"><%= c.name %></div>
            <div class="text-gray-400 text-sm truncate"><%= c.description %></div>
          </div>
          <% if c.url.present? %>
            <a href="<%= c.url %>" target="_blank" rel="noopener" class="text-purple-400 hover:text-purple-300 text-sm shrink-0">
              Visit →
            </a>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <%# How it works %>
  <div class="max-w-5xl mx-auto px-6 pb-24">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold text-white mb-3">How it works</h2>
      <p class="text-gray-400">Three steps. No accounts, no passwords, just your wallet.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <%# 1. Connect wallet %>
      <div class="relative bg-gray-800/30 border border-gray-700/50 rounded-2xl p-6 hover:border-purple-500/30 transition-colors">
        <div class="absolute top-4 right-4 text-xs font-bold text-gray-600">01</div>
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-600/20 to-purple-800/20 border border-purple-700/30 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3" />
          </svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Connect your wallet</h3>
        <p class="text-gray-400 text-sm leading-relaxed">Sign In With Solana. Phantom, Solflare, Backpack — any Wallet Standard extension.</p>
      </div>

      <%# 2. Pick a candidate %>
      <div class="relative bg-gray-800/30 border border-gray-700/50 rounded-2xl p-6 hover:border-blue-500/30 transition-colors">
        <div class="absolute top-4 right-4 text-xs font-bold text-gray-600">02</div>
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-600/20 to-blue-800/20 border border-blue-700/30 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Pick a candidate</h3>
        <p class="text-gray-400 text-sm leading-relaxed">Click Vote next to your favorite dApp. Your wallet signs the transaction.</p>
      </div>

      <%# 3. On-chain %>
      <div class="relative bg-gray-800/30 border border-gray-700/50 rounded-2xl p-6 hover:border-green-500/30 transition-colors">
        <div class="absolute top-4 right-4 text-xs font-bold text-gray-600">03</div>
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-600/20 to-green-800/20 border border-green-700/30 flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
          </svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Vote lands on-chain</h3>
        <p class="text-gray-400 text-sm leading-relaxed">Transaction confirmed on devnet. Vote counts update live for everyone.</p>
      </div>
    </div>
  </div>
</div>
